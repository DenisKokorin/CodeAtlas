DATABASE_URL=sqlite:///./codeatlas.db

# JWT auth
SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Swagger /docs Basic Auth
DOCS_USERNAME=codeatlas
DOCS_PASSWORD=0000
ENABLE_REDOC=false

# GitHub API
GITHUB_API_TOKEN=

# Documentation generation
DOCUMENTATION_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

DOCUMENTATION_MAX_INPUT_CHARS=12000
DOCUMENTATION_MAX_OUTPUT_TOKENS=1200
DOCUMENTATION_MAX_GITHUB_TREE_ITEMS=120
DOCUMENTATION_MAX_GITHUB_FILES=8
DOCUMENTATION_MAX_GITHUB_FILE_CHARS=3000
